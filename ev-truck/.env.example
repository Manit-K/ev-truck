APP_NAME=ev-truck
ENV=dev
APP_VERSION=0.1.0

GCP_PROJECT_ID=
GCP_REGION=asia-southeast1

# Host/WSL development. From another Compose service, use postgres instead of localhost.
DATABASE_URL=postgresql+psycopg2://evtruck:evtruck@localhost:5432/evtruck
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=vehicle_readings!A:Z
# Local service-account file only. On Cloud Run, prefer Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=
